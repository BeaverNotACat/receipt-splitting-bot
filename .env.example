### Infra
POSTGRES_AUTH_METHOD=trust
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Dev compose
POSTGRES_DB=receipt-splitting-bot
# Prod compose
POSTGRES_MULTIPLE_DATABASES="app, checkpoints"
POOLER_DATABASE_DSN=postgresql://postgres:postgres@database:5432/app

### App
DEBUG=true

KEY_VALUE_DSN=redis://key-value-store

TELEGRAM_TOKEN=...

OPENROUTER_API_KEY=...
OPENROUTER_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_ASR_MODEL=mistralai/voxtral-small-24b-2507 # No free audio models
OPENROUTER_AGENT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

RECEIPT_LOCK_PREFIX=receipt_lock
RECEIPT_LOCK_LIFETIME=300 # In seconds

# Dev compose
DATABASE_DSN=postgresql+psycopg://postgres:postgres@database:5432/app

# Prod compose
DATABASE_DSN=postgresql+psycopg://postgres:postgres@pooler:5432/app?application_name=receipt_app

CHECKPOINTER_DSN=postgresql+psycopg://postgres:postgres@database:5432/checkpoints?application_name=receipt_checkpointer
